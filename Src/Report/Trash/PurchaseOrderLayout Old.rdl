              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>We request you to send us your order confirmation within four working days to the mail address as mentioned in the header of the purchase order.</Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontFamily>Segoe UI</FontFamily>
                      <FontSize>11pt</FontSize>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
