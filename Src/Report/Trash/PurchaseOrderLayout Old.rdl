                      <FontSize>11pt</FontSize>
                      <FontWeight>Normal</FontWeight>
                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Invoices should always be sent to the no-reply mailbox invoices.SAP@damen.com in a pdf format OR to xml.invoices.SAP@damen.com for invoices in XML format. </Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
                      <FontFamily>Segoe UI</FontFamily>
                      <FontSize>11pt</FontSize>
