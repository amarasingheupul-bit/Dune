                      <TextDecoration>None</TextDecoration>
                      <Color>#000000</Color>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style />
              </Paragraph>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Reminders or questions should be sent to accountspayable@damen.com referencing the Damen entity. Provide a contact person's name and email for any invoice-related queries.</Value>
                    <Style>
                      <FontStyle>Normal</FontStyle>
